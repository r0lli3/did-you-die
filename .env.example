# Neon database connection string (set in Vercel env vars for API routes)
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# API URL for the mobile app to call Vercel API routes (optional — local-only mode without this)
EXPO_PUBLIC_API_URL=https://your-project.vercel.app
